# Copy to .env and set your key (used by npm run invoke:local).
# On AWS Lambda, set the same name in Configuration → Environment variables.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override model (default is gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Required for demo login custom token endpoint (/demo-login)
# Example value: {"type":"service_account", ...}
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account"}
DEMO_UID=demo-user-uid

