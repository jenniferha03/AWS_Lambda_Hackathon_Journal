# Firebase (required)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# ...

# API (production / shared): demo uses .../demo-login derived from this URL
# VITE_LAMBDA_URL=https://xxxx.execute-api.region.amazonaws.com/stage/gptJournalAnalyzer

# Local dev: demo button can use email/password when demo-login fetch fails, or without Lambda URL
# Create this user in Firebase Authentication (Email/Password). Never commit real passwords to git.
VITE_DEMO_EMAIL=demo@empathyjournal.app
VITE_DEMO_PASSWORD=
